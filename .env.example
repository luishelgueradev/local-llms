# local-llms — environment contract
# Copy to .env (bin/bootstrap-host.sh does this automatically) and fill values.
# .env is git-ignored. Never commit a populated .env.

# ── Compose project + host paths ────────────────────────────────────────────
# Compose project name. Determines the prefix on container/volume/network names
# (e.g. local-llms_backend). Do NOT change after first `compose up`.
COMPOSE_PROJECT_NAME=local-llms

# Host data root. All bind mounts in compose.yml reference this. The bootstrap
# script (bin/bootstrap-host.sh) creates the directory tree under this path.
# Phase 5: postgres-data and postgres-backups bind-mount under ${HOST_DATA_ROOT}.
# The pg-backup sidecar writes router-YYYY-MM-DDTHH.dump files daily; 7-day retention.
# Phase 9 (OPS-02 — bin/backup-postgres.sh) publishes the daily dump to the
# off-host restic destination configured under "Phase 9 — Off-host backups" below.
HOST_DATA_ROOT=/srv/local-llms

# ── Phase 2 — Router ────────────────────────────────────────────────────────
# Single bearer token used for all router model endpoints. Constant-time compared.
# Generate with: openssl rand -hex 32
# Format suggestion: prefix with `local-llms_` so accidental log leaks are searchable.
ROUTER_BEARER_TOKEN=

# ── Phase 3 — Registry VRAM envelope ────────────────────────────────────────
# VRAM envelope (GB) enforced per backend at registry load time.
# Sum of vram_budget_gb across all models pointing at the same backend MUST be <= this.
# Hardware default is 16 GB. Override for different-hardware deployments.
VRAM_ENVELOPE_GB=16

# ── Phase 8 — Ollama Cloud fallback ─────────────────────────────────────────
# Bearer token for https://ollama.com (Cloud API). Distinct from local Ollama,
# which has no auth. Get from https://ollama.com dashboard.
OLLAMA_API_KEY=

# ── Phase 5 — Postgres ──────────────────────────────────────────────────────
# Password for the `app` user. Postgres is on the internal `data` network only;
# this still bounds blast radius if the router is compromised.
# Generate with: openssl rand -hex 24
# Phase 5: seeds BOTH router and openwebui databases via postgres/initdb/01-init.sql
POSTGRES_PASSWORD=

# ── Phase 8 — Valkey ────────────────────────────────────────────────────────
# Valkey password (requirepass). Valkey is on the internal `data` network only.
# Required by Plan 08-01's router boot — ROUTER_VALKEY_PASSWORD env var
# in router/src/config/env.ts refuses to start with an empty value (min 8 chars).
# Generate with: openssl rand -hex 24
# The valkey container's --requirepass flag and the router's ioredis client
# read from the same value, so router and Valkey see consistent credentials.
# Note: ROUTER_VALKEY_URL is NOT exposed here — it is hardcoded to
# redis://valkey:6379 in compose.yml (operators don't override the internal
# data-plane hostname).
VALKEY_PASSWORD=

# ── Phase 6 — Traefik (TLS + edge) ──────────────────────────────────────────
# Tailnet hostname suffix (e.g. "my-corp" for *.my-corp.ts.net).
# Required by Phase 6 Traefik Host: rules on the `router.<TAILNET_HOSTNAME>.ts.net`
# and `chat.<TAILNET_HOSTNAME>.ts.net` subdomains.
# Discover yours with:
#   tailscale status --json | jq -r '.MagicDNSSuffix' | sed 's/\.$//' | sed 's/\.ts\.net$//'
TAILNET_HOSTNAME=

# DEPRECATED — Phase 6 picks Tailscale Serve for TLS (06-CONTEXT.md D-A2)
# instead of Let's Encrypt-in-Traefik. Left declared for backward compatibility;
# UNUSED with the current configuration. Safe to leave empty.
# (Re-enable only if you swap Tailscale Serve for Traefik+ACME in a future phase.)
TRAEFIK_ACME_EMAIL=

# Traefik basic-auth middleware credentials gating `chat.<TAILNET_HOSTNAME>.ts.net`
# (the unauth Open WebUI surface — D-C4). Format: user:$apr1$...:...
#
# Generate with (bcrypt — Traefik's recommended algorithm):
#   htpasswd -nB admin
# Paste the output VERBATIM into the value below — do NOT double any `$` signs.
#
# IMPORTANT — Compose interpolation rule (empirically verified 2026-05-16 against
# Docker Compose v5.x with `docker inspect` confirming the runtime label value):
# Compose interpolation does NOT re-interpolate the SUBSTITUTED value of an
# env-var. So when this value flows from .env into the Compose label
#   - "traefik.http.middlewares.webui-basic-auth.basicauth.users=${TRAEFIK_BASIC_AUTH}"
# in compose.yml, the literal `$` characters pass through to Traefik unchanged
# — which is exactly what Traefik's BasicAuth middleware expects.
#
# Note: `docker compose config` PRINTS this label with `$` doubled to `$$` for
# re-interpolation safety in case you pipe its output back into a Compose file.
# That's a DISPLAY-time artifact only; `docker inspect <container>` shows the
# correct single-`$` value at runtime.
#
# The `$$` doubling rule applies ONLY to literal `$` typed directly into the
# compose.yml YAML content (see the pg-backup service's `command:` array, which
# uses `$$STAMP` to defer expansion to the shell). It does NOT apply to env-var
# VALUES read from .env.
#
# The file-provider dynamic YAML at traefik/dynamic/*.yml also reads `$`
# VERBATIM with no escaping — but Phase 6 declares webui-basic-auth via Docker
# label (not file provider) so .env can be the single source of truth.
TRAEFIK_BASIC_AUTH=

# Open WebUI session-signing key + at-rest encryption key (D-C8).
# Pin so the DB backups round-trip across container recreates (Pitfall 10 — if
# OWUI generates a fresh key on a recreate, prior sessions break and any
# at-rest-encrypted fields become unreadable).
# Generate ONCE with: openssl rand -hex 32
# NEVER rotate without recreating the openwebui DB.
OWUI_SECRET_KEY=

# ── Phase 6 smoke (NOT used by Traefik or OWUI; only by bin/smoke-test-traefik.sh) ──
# Plain basic-auth credentials used by the smoke test to exercise the
# chat.<TAILNET_HOSTNAME>.ts.net basic-auth gate. MUST match the credentials
# that hashed to TRAEFIK_BASIC_AUTH above. Smoke-only — does not affect Traefik.
# If you rotate TRAEFIK_BASIC_AUTH, rotate these in lockstep.
TRAEFIK_BASIC_AUTH_USER=
TRAEFIK_BASIC_AUTH_PASS_PLAIN=

# ── Phase 7 — Embeddings + vLLM + GPU Telemetry ─────────────────────────────
# Grafana internal admin password. SEPARATE from Traefik basic-auth at the edge
# (TRAEFIK_BASIC_AUTH above) — Grafana has its own user model and the edge
# basic-auth is the dual-layer auth gate Open WebUI also uses. The Grafana
# admin password becomes the fallback gate when reached via the 127.0.0.1:80
# LAN bypass that skips Tailscale Serve.
#
# Required by Plan 07-02's `grafana:` service (env GF_SECURITY_ADMIN_PASSWORD).
# No default — must be set before `docker compose up grafana`.
# Generate with: openssl rand -hex 24
GRAFANA_ADMIN_PASSWORD=

# Optional HuggingFace Hub token. Empty default is fine for Phase 7:
# - Qwen/Qwen2.5-7B-Instruct-AWQ (vLLM chat) is a PUBLIC HF model.
# - BAAI/bge-m3 (vLLM embed) is a PUBLIC HF model.
# Set ONLY if a later phase pins a gated HF model OR you run behind a
# private HF mirror that requires auth.
#
# Wired into vllm: and vllm-embed: compose services as
# `HUGGINGFACE_HUB_TOKEN=${HUGGINGFACE_HUB_TOKEN:-}` — an empty value
# interpolates to the empty string and does NOT emit a broken auth header.
#
# Get a token at https://huggingface.co/settings/tokens (READ scope is enough).
HUGGINGFACE_HUB_TOKEN=

# ── Phase 8 — Circuit breaker tunables (CIRCUIT_*) ───────────────────────────
# Per-backend circuit breaker defaults (Plan 08-04 / D-B2). The router
# refuses to start if CIRCUIT_FAILURE_THRESHOLD < 1 or any *_MS value < 1000
# (zod validator in router/src/config/env.ts).
#
# CIRCUIT_FAILURE_THRESHOLD — consecutive failures within CIRCUIT_WINDOW_MS
#   that flip the breaker to 'open'. Default 5: matches the 5xx-streak-in-30s
#   pattern from Plan 08-04 D-B2; lower if you want the breaker to be more
#   sensitive (rare in single-user agents).
# CIRCUIT_WINDOW_MS — rolling window over which failures are counted.
#   Default 30000 (30s). Increase if your upstream has bursty-but-recoverable
#   error patterns that should not trip the breaker.
# CIRCUIT_COOLDOWN_MS — duration the breaker stays open before the next
#   half-open probe. Default 60000 (60s); flows through into the
#   Retry-After: 60 header on 503 backend_circuit_open envelopes.
CIRCUIT_FAILURE_THRESHOLD=5
CIRCUIT_WINDOW_MS=30000
CIRCUIT_COOLDOWN_MS=60000

# ── Phase 8 — Rate limit (ROUTE-11) ─────────────────────────────────────────
# Per-bearer-token-per-minute rate limit (Plan 08-06 / D-D3). Default 600
# RPM (single-user agent stack assumption) — raise if multi-agent workloads
# exhibit unnatural 429 patterns. Out-of-range (< 1) fails the env validator.
#
# Backed by Valkey counters keyed at `ratelimit:${bearer_hash_8char}:${epoch_minute}`
# with TTL = 65s. Inspect counters with:
#   docker compose exec -T valkey valkey-cli -a $VALKEY_PASSWORD KEYS 'ratelimit:*'
ROUTER_RATE_LIMIT_RPM=600

# ── Phase 9 — Off-host backups (OPS-02) ─────────────────────────────────────
# bin/backup-postgres.sh publishes the newest pg-backup-sidecar dump to an
# off-host restic repository. The script is INVOKED FROM HOST CRONTAB (not a
# Compose sidecar) — see README §Operations §Off-host backups for the recipe.
#
# Pre-step (operator runs ONCE, before the first script run):
#   sudo apt install restic        # Debian/Ubuntu — or download from restic.net
#   restic -r "$BACKUP_RESTIC_REPO" init   # interactive password prompt
#
# An empty BACKUP_RESTIC_REPO disables the off-host publish (the script exits 1
# with a clear "off-host backup not configured" message — operator decides
# whether to schedule the crontab entry).
#
# Sample repo URIs (pick one for your hardware):
#   sftp:backup-host:/srv/restic-repos/local-llms   # LAN SSH target (recommended)
#   /mnt/external-hdd/restic-repos/local-llms       # local-path (external HDD)
#   b2:my-bucket-name:/local-llms                   # Backblaze B2 (cloud)
#   rest:https://rest-server.lan/local-llms         # rest-server (LAN)
#
# Per CONTEXT §Specifics line 74: restic chosen over rclone — encryption built
# in (AES-256 + Poly1305); simpler retention semantics (`forget --prune`).
BACKUP_RESTIC_REPO=

# Restic repository encryption key.
#
# !! CRITICAL — LOSING THIS PASSWORD MEANS LOSING THE BACKUPS !!
# Restic encrypts every snapshot with a key derived from this password. There
# is NO recovery path — restic cannot recover lost passwords. The off-host
# repo is irretrievable noise without it.
#
# Generate with:
#   openssl rand -hex 32
#
# Storage recommendation: a password manager OUTSIDE the host filesystem.
# Storing it ONLY in this .env file means the backup loses its disaster-recovery
# value the moment the host disk fails (the original failure mode this whole
# off-host backup is meant to address).
#
# bin/backup-postgres.sh enforces a minimum length of 16 chars as a cheap typo
# gate; the openssl recipe above produces 64 chars.
#
# At-rest encryption of `.env` itself (sops/age/vault) is a v2 concern
# (CONTEXT §Deferred line 85).
BACKUP_RESTIC_PASSWORD=

# Optional override of the default retention policy. Default (when empty):
#   --keep-daily 7 --keep-weekly 4 --keep-monthly 6
# Total ~17 snapshots after 6 months of daily backups.
#
# Set this to override — example for long-retention archive:
#   BACKUP_KEEP_POLICY="--keep-daily 30 --keep-monthly 24"
#
# The value is splatted verbatim into restic's argv — make sure the flags are
# valid restic `forget` flags (see `restic forget --help`).
BACKUP_KEEP_POLICY=
