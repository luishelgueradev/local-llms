# local-llms — environment contract
# Copy to .env (bin/bootstrap-host.sh does this automatically) and fill values.
# .env is git-ignored. Never commit a populated .env.

# ── Compose project + host paths ────────────────────────────────────────────
# Compose project name. Determines the prefix on container/volume/network names
# (e.g. local-llms_backend). Do NOT change after first `compose up`.
COMPOSE_PROJECT_NAME=local-llms

# Host data root. All bind mounts in compose.yml reference this. The bootstrap
# script (bin/bootstrap-host.sh) creates the directory tree under this path.
# Phase 5: postgres-data and postgres-backups bind-mount under ${HOST_DATA_ROOT}.
# The pg-backup sidecar writes router-YYYY-MM-DDTHH.dump files daily; 7-day retention.
# Phase 9 (OPS-02) will move to off-host backup destination.
HOST_DATA_ROOT=/srv/local-llms

# ── Phase 2 — Router ────────────────────────────────────────────────────────
# Single bearer token used for all router model endpoints. Constant-time compared.
# Generate with: openssl rand -hex 32
# Format suggestion: prefix with `local-llms_` so accidental log leaks are searchable.
ROUTER_BEARER_TOKEN=

# ── Phase 3 — Registry VRAM envelope ────────────────────────────────────────
# VRAM envelope (GB) enforced per backend at registry load time.
# Sum of vram_budget_gb across all models pointing at the same backend MUST be <= this.
# Hardware default is 16 GB. Override for different-hardware deployments.
VRAM_ENVELOPE_GB=16

# ── Phase 8 — Ollama Cloud fallback ─────────────────────────────────────────
# Bearer token for https://ollama.com (Cloud API). Distinct from local Ollama,
# which has no auth. Get from https://ollama.com dashboard.
OLLAMA_API_KEY=

# ── Phase 5 — Postgres ──────────────────────────────────────────────────────
# Password for the `app` user. Postgres is on the internal `data` network only;
# this still bounds blast radius if the router is compromised.
# Generate with: openssl rand -hex 24
# Phase 5: seeds BOTH router and openwebui databases via postgres/initdb/01-init.sql
POSTGRES_PASSWORD=

# ── Phase 8 — Valkey ────────────────────────────────────────────────────────
# Valkey password (requirepass). Valkey is on the internal `data` network only.
# Generate with: openssl rand -hex 24
VALKEY_PASSWORD=

# ── Phase 6 — Traefik (TLS + edge) ──────────────────────────────────────────
# Tailnet hostname suffix (e.g. "my-corp" for *.my-corp.ts.net).
# Required by Phase 6 Traefik Host: rules on the `router.<TAILNET_HOSTNAME>.ts.net`
# and `chat.<TAILNET_HOSTNAME>.ts.net` subdomains.
# Discover yours with:
#   tailscale status --json | jq -r '.MagicDNSSuffix' | sed 's/\.$//' | sed 's/\.ts\.net$//'
TAILNET_HOSTNAME=

# DEPRECATED — Phase 6 picks Tailscale Serve for TLS (06-CONTEXT.md D-A2)
# instead of Let's Encrypt-in-Traefik. Left declared for backward compatibility;
# UNUSED with the current configuration. Safe to leave empty.
# (Re-enable only if you swap Tailscale Serve for Traefik+ACME in a future phase.)
TRAEFIK_ACME_EMAIL=

# Traefik basic-auth middleware credentials gating `chat.<TAILNET_HOSTNAME>.ts.net`
# (the unauth Open WebUI surface — D-C4). Format: user:$apr1$...:...
#
# Generate with (bcrypt — Traefik's recommended algorithm):
#   htpasswd -nB admin | sed -e 's/\$/\$\$/g'
#
# IMPORTANT: the sed step DOUBLES `$` → `$$` because Compose label interpolation
# eats a single `$`. After Compose interpolates the value into the Traefik label
# (see compose.yml services.traefik.labels), the rendered label gets single `$`
# back — which is exactly what Traefik's BasicAuth middleware expects.
#
# This $$-escaping rule applies ONLY when the value is consumed via a Compose
# label (the path used here). A file-provider YAML at traefik/dynamic/*.yml
# reads `$` VERBATIM with no escaping needed.
TRAEFIK_BASIC_AUTH=

# Open WebUI session-signing key + at-rest encryption key (D-C8).
# Pin so the DB backups round-trip across container recreates (Pitfall 10 — if
# OWUI generates a fresh key on a recreate, prior sessions break and any
# at-rest-encrypted fields become unreadable).
# Generate ONCE with: openssl rand -hex 32
# NEVER rotate without recreating the openwebui DB.
OWUI_SECRET_KEY=
