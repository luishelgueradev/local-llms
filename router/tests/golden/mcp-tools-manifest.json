            "type": "string"
          },
          "temperature": {
            "type": "number"
          },
          "max_output_tokens": {
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991
          },
          "stream": {
            "type": "boolean"
          }
        },
        "required": [
          "model",
