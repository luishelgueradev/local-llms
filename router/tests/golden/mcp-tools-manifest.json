    {
      "name": "rerank",
      "title": "Rerank documents against a query",
      "description": "Rerank candidate documents against a query. Returns per-document relevance_score in structuredContent.results; content carries a one-line stamp (\"reranked N docs vs query, model=M\"). Cohere/Jina-compatible.",
      "inputSchema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "properties": {
          "model": {
            "type": "string",
            "minLength": 1
          },
          "query": {
            "type": "string",
            "minLength": 1
          },
          "documents": {
            "minItems": 1,
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "top_n": {
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991
          },
          "return_documents": {
            "type": "boolean"
          }
        },
        "required": [
          "model",
          "query",
          "documents"
        ],
        "additionalProperties": {}
      },
      "execution": {
